# PitchPilot AI Environment Configuration
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in your API key below.
# 3. Restart the app.
#
# DO NOT commit .env to version control. It is already in .gitignore.

PITCHPILOT_AI_API_KEY=
PITCHPILOT_AI_BASE_URL=https://api.openai.com/v1
PITCHPILOT_AI_MODEL=gpt-4o-mini
