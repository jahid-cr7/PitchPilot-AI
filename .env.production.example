# PitchPilot AI — Production Environment Template
#
# 1. Copy this file to .env:
#    cp .env.production.example .env
#
# 2. Replace placeholder values with your real configuration.
# 3. Do NOT commit .env to version control (it is in .gitignore).
# 4. Run: docker compose -f docker-compose.prod.yml up --build -d

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
PITCHPILOT_ENV=production

# ---------------------------------------------------------------------------
# Paths (inside containers)
# ---------------------------------------------------------------------------
PITCHPILOT_DB_PATH=/app/data/pitchpilot.db
PITCHPILOT_UPLOAD_DIR=/app/uploads

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# Example: http://localhost:3000,https://yourdomain.com
# ---------------------------------------------------------------------------
PITCHPILOT_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Upload limits
# ---------------------------------------------------------------------------
PITCHPILOT_MAX_UPLOAD_MB=200

# ---------------------------------------------------------------------------
# AI Provider
# Replace with your real API key and provider settings.
# Defaults below target Google Gemini via its OpenAI-compatible endpoint.
# For OpenAI, use:
#   PITCHPILOT_AI_BASE_URL=https://api.openai.com/v1
#   PITCHPILOT_AI_MODEL=gpt-4o-mini
# ---------------------------------------------------------------------------
PITCHPILOT_AI_API_KEY=replace_me
PITCHPILOT_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
PITCHPILOT_AI_MODEL=gemini-3.5-flash

# ---------------------------------------------------------------------------
# Authentication (JWT)
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------------------------
PITCHPILOT_JWT_SECRET=replace_me_with_a_long_random_string
PITCHPILOT_JWT_EXPIRES_MINUTES=1440

# ---------------------------------------------------------------------------
# Frontend build-time API URL
# This is baked into the React bundle at Docker build time.
# Use the external URL where the browser will reach the API.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Public domains (used by deployment scripts and Caddyfile)
# Replace with your real domains before deploying to VPS.
# ---------------------------------------------------------------------------
PUBLIC_WEB_DOMAIN=https://yourdomain.com
PUBLIC_API_DOMAIN=https://api.yourdomain.com
